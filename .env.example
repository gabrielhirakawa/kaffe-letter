SERVER_ADDR=:8080
DATABASE_PATH=./data/newsletter.db
LOG_LEVEL=info
TIMEZONE=America/Sao_Paulo
HTTP_TIMEOUT_SECONDS=20

# Bootstrap de credenciais e defaults operacionais.
OPENAI_MODEL=gpt-5-nano
OPENAI_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=
EMAIL_SUBJECT=Newsletter diaria
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
TELEGRAM_DISABLE_WEB_PREVIEW=true

# Opcional: use .env para headless/bootstrap.
# Depois do primeiro boot, o painel admin e o SQLite passam a ser a fonte de verdade.
# As fontes RSS e a curadoria editorial continuam sendo configuradas no admin.
