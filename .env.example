OPENAI_API_KEY=<SECRET>
OPENAI_MODEL=gpt-5-nano
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

RSS_FEEDS=https://hnrss.org/frontpage,https://hnrss.org/newest?q=golang+OR+python+OR+javascript,http://feeds.arstechnica.com/arstechnica/index,https://feed.infoq.com/,https://github.blog/feed/,https://stackoverflow.blog/feed/,https://rss.nytimes.com/services/xml/rss/nyt/Technology.xml,https://rss.nytimes.com/services/xml/rss/nyt/Business.xml,https://rss.nytimes.com/services/xml/rss/nyt/Economy.xml,https://news.google.com/rss/search?q=tecnologia,https://news.google.com/rss/search?q=programacao,https://news.google.com/rss/search?q=economia
MAX_ITEMS_PER_FEED=25
MAX_ITEMS_TOTAL=220
CANDIDATE_POOL_SIZE=80
CURATED_ITEMS_COUNT=10
CURATION_CHUNK_SIZE=15

TARGET_DOMAINS=github.blog,stackoverflow.blog,infoq.com,arstechnica.com,nytimes.com
TARGET_KEYWORDS=ai,openai,programming,devtools,golang,python,javascript,economy,macroeconomics,startups
BLOCKED_DOMAINS=

WEIGHT_RELEVANCE=0.45
WEIGHT_NOVELTY=0.25
WEIGHT_CREDIBILITY=0.20
WEIGHT_TARGET=0.10
MAX_PER_DOMAIN=2

TIMEZONE=America/Sao_Paulo

# Preferencial: URL única SMTP (formato smtp://usuario:senha@host:porta)
SMTP_URL=smtp://seu-email%40gmail.com:sua-app-password@smtp.gmail.com:587
EMAIL_FROM=seu-email@gmail.com
EMAIL_TO=dest1@email.com,dest2@email.com
EMAIL_SUBJECT=Newsletter diária com IA

TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
TELEGRAM_DISABLE_WEB_PREVIEW=true

DATABASE_PATH=./data/newsletter.db
HTTP_TIMEOUT_SECONDS=120
LOG_LEVEL=info
REQUIRE_AI_PTBR=true
